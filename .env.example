# Vendo-OS Environment Variables
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local
#
# Ask Toby or Max for shared API keys

# === CURRENTLY ACTIVE (required for scripts to work) ===

# Fathom — Meeting transcription (https://fathom.video/settings/api)
FATHOM_API_KEY=
FATHOM_WEBHOOK_SECRET=

# GoHighLevel — CRM and pipeline (Private Integration Token from GHL settings)
GHL_API_KEY=
GHL_LOCATION_ID=

# Slack — Team communication (Bot token from Slack app settings)
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# Google Drive — File access (paths to credential files in .secrets/)
# These are set automatically by scripts/setup.sh — no need to edit
GDRIVE_CREDENTIALS_PATH=
GDRIVE_OAUTH_PATH=

# === NOT YET CONNECTED (fill in when integrations are built) ===

# Xero — Finance and invoicing
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Ad Platforms
META_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
MICROSOFT_ADS_CLIENT_ID=

# Reporting
AGENCY_ANALYTICS_API_KEY=
TRIPLE_WHALE_API_KEY=

# SEO
AHREFS_API_KEY=

# Ecommerce
SHOPIFY_API_KEY=

# AI
ANTHROPIC_API_KEY=
