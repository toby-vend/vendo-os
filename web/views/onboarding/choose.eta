<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Client Onboarding — Vendo Digital</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body class="onboard-body">
  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
  <div class="bg-orb bg-orb-3"></div>

  <main class="onboard-container" aria-label="Onboarding">
    <div class="onboard-logo">V</div>
    <h1 class="onboard-brand">Vendo Digital</h1>
    <p class="onboard-subtitle">Client Onboarding</p>

    <div class="onboard-card onboard-choose-card">
      <h2 class="onboard-choose-heading">Welcome</h2>
      <p class="onboard-choose-text">Please select the option that best describes your practice to get started.</p>

      <div class="onboard-choose-grid">
        <% for (const tpl of it.templates) { %>
          <form method="POST" action="/onboard/start" class="onboard-choose-option">
            <input type="hidden" name="templateId" value="<%= tpl.id %>">
            <div class="onboard-choose-icon">
              <% if (tpl.type === 'single') { %>
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              <% } else { %>
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="7" height="18" rx="1"/>
                  <rect x="9" y="3" width="7" height="18" rx="1"/>
                  <rect x="17" y="3" width="6" height="18" rx="1"/>
                </svg>
              <% } %>
            </div>
            <h3><%= tpl.title %></h3>
            <p><%= tpl.subtitle %></p>
            <button type="submit" class="wizard-btn wizard-btn-primary">Get Started</button>
          </form>
        <% } %>
      </div>
    </div>

    <p class="onboard-footer">Vendo Digital &mdash; Client Onboarding</p>
  </main>
</body>
</html>
