<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vendo OS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
</head>
<body>
  <div class="app-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <div class="logo-icon">V</div>
          <div class="logo-text">
            <span class="logo-name">Vendo OS</span>
            <span class="logo-plan">Team Dashboard</span>
          </div>
        </div>
      </div>

      <% const canSee = (slug) => it.user?.role === 'admin' || (it.user?.allowedRoutes || []).includes(slug); %>
      <nav class="sidebar-nav">
        <div class="nav-section">
          <span class="nav-section-label">Menu</span>
          <% if (canSee('dashboard')) { %>
          <a href="/" class="nav-item<%= it.currentPath === '/' ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            <span class="nav-label">Dashboard</span>
          </a>
          <% } %>
          <% if (canSee('meetings')) { %>
          <a href="/meetings" class="nav-item<%= it.currentPath?.startsWith('/meetings') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <span class="nav-label">Meetings</span>
          </a>
          <% } %>
          <% if (canSee('action-items')) { %>
          <a href="/action-items" class="nav-item<%= it.currentPath?.startsWith('/action-items') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            <span class="nav-label">Actions</span>
          </a>
          <% } %>
          <% if (canSee('clients')) { %>
          <a href="/clients" class="nav-item<%= it.currentPath?.startsWith('/clients') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            <span class="nav-label">Clients</span>
          </a>
          <% } %>
          <% if (canSee('pipeline')) { %>
          <a href="/pipeline" class="nav-item<%= it.currentPath?.startsWith('/pipeline') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M16 8l-4 4-4-4"/><path d="M12 12v4"/></svg>
            <span class="nav-label">Pipeline</span>
          </a>
          <% } %>
          <% if (canSee('ads')) { %>
          <a href="/ads" class="nav-item<%= it.currentPath?.startsWith('/ads') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
            <span class="nav-label">Ads</span>
          </a>
          <% } %>
          <% if (canSee('briefs')) { %>
          <a href="/briefs" class="nav-item<%= it.currentPath?.startsWith('/briefs') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span class="nav-label">Briefs</span>
          </a>
          <% } %>
          <% if (canSee('drive')) { %>
          <a href="/drive" class="nav-item<%= it.currentPath?.startsWith('/drive') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 19.5h20L12 2z"/><path d="M8.5 19.5L12 13l3.5 6.5"/><path d="M15.5 13H22l-6.5-11"/></svg>
            <span class="nav-label">Drive</span>
          </a>
          <% } %>
          <% if (canSee('tasks')) { %>
          <a href="/tasks" class="nav-item<%= it.currentPath?.startsWith('/tasks') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="nav-label">Tasks</span>
          </a>
          <% } %>
          <% if (canSee('chat')) { %>
          <a href="/chat" class="nav-item<%= it.currentPath?.startsWith('/chat') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            <span class="nav-label">Chat</span>
          </a>
          <% } %>
        </div>
        <div class="nav-section">
          <span class="nav-section-label">System</span>
          <% if (canSee('sync-status')) { %>
          <a href="/sync-status" class="nav-item<%= it.currentPath?.startsWith('/sync-status') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23,4 23,10 17,10"/><polyline points="1,20 1,14 7,14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
            <span class="nav-label">Sync Status</span>
          </a>
          <% } %>
        </div>
        <% if (it.user?.role === 'admin') { %>
        <div class="nav-section">
          <span class="nav-section-label">Admin</span>
          <a href="/admin/users" class="nav-item<%= it.currentPath?.startsWith('/admin/users') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            <span class="nav-label">Users</span>
          </a>
          <a href="/admin/permissions" class="nav-item<%= it.currentPath?.startsWith('/admin/permissions') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <span class="nav-label">Permissions</span>
          </a>
          <a href="/admin/usage" class="nav-item<%= it.currentPath?.startsWith('/admin/usage') ? ' active' : '' %>">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
            <span class="nav-label">Usage</span>
          </a>
        </div>
        <% } %>
      </nav>

      <div class="sidebar-footer">
        <a href="/settings" class="nav-item<%= it.currentPath?.startsWith('/settings') ? ' active' : '' %>" style="margin-bottom: 0.25rem;">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          <span class="nav-label">Settings</span>
        </a>
        <button class="sidebar-toggle" id="sidebar-toggle" onclick="toggleSidebar()">
          <svg class="nav-icon toggle-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15,18 9,12 15,6"/></svg>
          <span class="nav-label">Collapse</span>
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
      <header class="topbar">
        <div class="topbar-left">
          <button class="mobile-menu-btn" onclick="toggleSidebar()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <% const pageNames = { '/': 'Dashboard', '/meetings': 'Meetings', '/action-items': 'Action Items', '/clients': 'Clients', '/pipeline': 'Pipeline', '/ads': 'Ad Performance', '/briefs': 'Daily Briefs', '/drive': 'Google Drive', '/sync-status': 'Sync Status', '/admin/users': 'User Management', '/admin/permissions': 'Channel Permissions', '/admin/usage': 'API Usage', '/change-password': 'Change Password', '/settings': 'Account Settings', '/chat': 'AI Chat', '/tasks': 'Tasks', '/tasks/new': 'New Task' }; %>
          <h1 class="topbar-title"><%= pageNames[it.currentPath] || 'Vendo OS' %></h1>
        </div>
        <div class="topbar-right" style="display: flex; align-items: center; gap: 1rem;">
          <span class="topbar-date"><%= new Date().toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
          <% if (it.user) { %>
          <span style="font-size: 13px; color: #94A3B8;"><%= it.user.name %></span>
          <a href="/logout" style="font-size: 12px; color: #64748B; text-decoration: none; padding: 4px 10px; border: 1px solid rgba(255,255,255,0.08); border-radius: 6px;">Logout</a>
          <% } %>
        </div>
      </header>

      <main class="main-content">
        <% if (it.user && !it.user.googleConnected && it.currentPath !== '/settings' && !it.currentPath?.startsWith('/auth/')) { %>
        <div id="google-connect-banner" style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 1.25rem; margin-bottom: 1rem; background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); border-radius: 10px;">
          <div style="font-size: 14px; color: #E2E8F0;">
            <strong>Connect your Google account</strong> to access Drive, Gmail, and Calendar within VendoOS.
          </div>
          <div style="display: flex; gap: 0.5rem; flex-shrink: 0;">
            <a href="/auth/google/connect" style="padding: 6px 14px; font-size: 12px; color: #0B0B0B; background: #22C55E; border-radius: 6px; text-decoration: none; font-weight: 600; white-space: nowrap;">Connect Google</a>
            <button onclick="this.parentElement.parentElement.remove(); localStorage.setItem('dismissGoogleBanner','1')" style="padding: 6px 10px; font-size: 12px; color: #94A3B8; background: none; border: 1px solid rgba(255,255,255,0.08); border-radius: 6px; cursor: pointer;">Dismiss</button>
          </div>
        </div>
        <script>if(localStorage.getItem('dismissGoogleBanner')==='1'){var b=document.getElementById('google-connect-banner');if(b)b.remove();}</script>
        <% } %>
        <%~ it.body %>
      </main>
    </div>
  </div>

  <script>
  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const layout = document.querySelector('.app-layout');
    sidebar.classList.toggle('collapsed');
    layout.classList.toggle('sidebar-collapsed');
    localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
  }
  // Restore state
  if (localStorage.getItem('sidebarCollapsed') === 'true') {
    document.getElementById('sidebar').classList.add('collapsed');
    document.querySelector('.app-layout').classList.add('sidebar-collapsed');
  }
  </script>
</body>
</html>
