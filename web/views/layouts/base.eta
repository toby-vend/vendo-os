<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vendo OS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
</head>
<body>
  <div class="app-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <div class="logo-icon">V</div>
          <div class="logo-text">
            <span class="logo-name">Vendo OS</span>
            <span class="logo-plan">Team Dashboard</span>
          </div>
        </div>
      </div>

      <% const canSee = (slug) => it.user?.role === 'admin' || (it.user?.allowedRoutes || []).includes(slug); %>
      <%
        const p = it.currentPath || '';
        const isInGroup = (paths) => paths.some(x => p === x || p.startsWith(x + '/'));
      %>
      <nav class="sidebar-nav">
        <% (it.sidebarConfig || []).forEach(function(group) {
          // Admin-only groups: skip for non-admins
          if (group.adminOnly && it.user?.role !== 'admin') return;

          // Filter visible items by permission + hidden flag
          const visibleItems = group.items.filter(function(item) {
            if (item.hidden) return false;
            if (!item.permission) return true;
            return canSee(item.permission);
          });
          if (visibleItems.length === 0) return;

          // Collect hrefs for auto-open detection
          const hrefs = visibleItems.map(function(item) { return item.href; });
          const isSingle = visibleItems.length === 1 && group.icon;
        %>

        <% if (isSingle) { %>
        <div class="nav-group nav-group-single"<%= group.id === 'home' ? ' style="padding-top: 0.25rem;"' : '' %>>
          <a href="<%= visibleItems[0].href %>" class="nav-item<%= (visibleItems[0].href === '/' ? p === '/' : p.startsWith(visibleItems[0].href)) ? ' active' : '' %>"<%= group.id === 'home' ? ' style="margin: 0 0.5rem; width: calc(100% - 1rem);"' : '' %>>
            <%~ group.icon %>
            <span class="nav-label"><%= visibleItems[0].label %></span>
          </a>
        </div>
        <% } else { %>
        <div class="nav-group<%= isInGroup(hrefs) ? ' open' : '' %>">
          <button class="nav-group-label" onclick="toggleNavGroup(this)">
            <span class="nav-label"><%= group.label %></span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,6 15,12 9,18"/></svg>
          </button>
          <div class="nav-group-children">
            <% visibleItems.forEach(function(item) { %>
            <a href="<%= item.href %>" class="nav-item nav-child<%= (item.href === '/' ? p === '/' : p.startsWith(item.href)) ? ' active' : '' %>">
              <span class="nav-label"><%= item.label %></span>
            </a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <% }); %>
      </nav>

      <div class="sidebar-footer">
        <a href="/settings" class="nav-item<%= it.currentPath?.startsWith('/settings') ? ' active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          <span class="nav-label">Settings</span>
        </a>
        <button class="sidebar-toggle" id="sidebar-toggle" onclick="toggleSidebar()" title="Collapse sidebar">
          <svg class="toggle-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15,18 9,12 15,6"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
      <header class="topbar">
        <div class="topbar-left">
          <button class="mobile-menu-btn" onclick="toggleSidebar()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <% const pageNames = { '/': 'Dashboard', '/meetings': 'Meetings', '/action-items': 'Action Items', '/clients': 'Clients', '/pipeline': 'Pipeline', '/ads': 'Ad Performance', '/briefs': 'Daily Briefs', '/drive': 'Google Drive', '/sync-status': 'Sync Status', '/admin/users': 'User Management', '/admin/permissions': 'Channel Permissions', '/admin/usage': 'API Usage', '/change-password': 'Change Password', '/settings': 'Account Settings', '/chat': 'AI Chat', '/tasks': 'Content Tasks', '/tasks/new': 'New Task', '/asana-tasks': 'Asana Tasks', '/skills': 'Skills Library', '/growth': 'Growth', '/admin/clients': 'Client Hub', '/admin/client-mapping': 'Client Mapping', '/admin/portal-users': 'Portal Users', '/admin/sidebar': 'Sidebar Menu' }; if (it.currentPath?.startsWith('/growth/linkedin/')) pageNames[it.currentPath] = 'LinkedIn Post'; pageNames['/dashboards/ads'] = 'Ads Dashboard'; pageNames['/dashboards/meta-dental'] = 'Meta Ads — Dental'; pageNames['/dashboards/gads-dental'] = 'Google Ads — Dental'; pageNames['/dashboards/reporting-hub'] = 'Client Reporting Hub'; pageNames['/dashboards/client-mer'] = 'Client MER / ROAS'; pageNames['/dashboards/finance'] = 'Financial Dashboard'; pageNames['/dashboards/time-tracking'] = 'Time Tracking'; pageNames['/dashboards/capacity'] = 'Capacity Modelling'; pageNames['/dashboards/gads-ecom'] = 'Google Ads — Ecom'; pageNames['/dashboards/profitability'] = 'Client Profitability'; pageNames['/dashboards/pipeline'] = 'Pipeline Tracker'; pageNames['/dashboards/reviews'] = 'Performance Reviews'; pageNames['/client-database'] = 'Client Database'; pageNames['/operations'] = 'Operations Hub'; pageNames['/skills-library'] = 'Skills Library'; if (it.currentPath?.startsWith('/skills/outputs/')) pageNames[it.currentPath] = 'Saved Output'; else if (it.currentPath?.startsWith('/skills/') && it.currentPath !== '/skills') pageNames[it.currentPath] = 'Skills Library'; %>
          <h1 class="topbar-title"><%= pageNames[it.currentPath] || 'Vendo OS' %></h1>
        </div>
        <div class="topbar-right" style="display: flex; align-items: center; gap: 1rem;">
          <span class="topbar-date"><%= new Date().toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
          <% if (it.user) { %>
          <!-- Notification bell -->
          <div id="notif-bell" style="position: relative; cursor: pointer;" onclick="toggleNotifPanel()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="color: #94A3B8;"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            <span id="notif-badge" style="display: none; position: absolute; top: -4px; right: -4px; background: #EF4444; color: #fff; font-size: 10px; font-weight: 700; min-width: 16px; height: 16px; border-radius: 999px; text-align: center; line-height: 16px;"></span>
          </div>
          <!-- Notification dropdown -->
          <div id="notif-panel" style="display: none; position: absolute; top: 48px; right: 1rem; width: 360px; max-height: 420px; overflow-y: auto; background: #141414; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.5); z-index: 999; font-size: 13px;">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.06);">
              <strong style="color: #E2E8F0;">Notifications</strong>
              <button onclick="markAllNotifRead()" style="background: none; border: none; color: #22C55E; cursor: pointer; font-size: 12px;">Mark all read</button>
            </div>
            <div id="notif-list" style="padding: 0.5rem;"></div>
          </div>
          <span style="font-size: 13px; color: #94A3B8;"><%= it.user.name %></span>
          <a href="/logout" style="font-size: 12px; color: #64748B; text-decoration: none; padding: 4px 10px; border: 1px solid rgba(255,255,255,0.08); border-radius: 6px;">Logout</a>
          <% } %>
        </div>
      </header>

      <main class="main-content">
        <% if (it.user && !it.user.googleConnected && it.currentPath !== '/settings' && !it.currentPath?.startsWith('/auth/')) { %>
        <div id="google-connect-banner" style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 1.25rem; margin-bottom: 1rem; background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); border-radius: 10px;">
          <div style="font-size: 14px; color: #E2E8F0;">
            <strong>Connect your Google account</strong> to access Drive, Gmail, and Calendar within VendoOS.
          </div>
          <div style="display: flex; gap: 0.5rem; flex-shrink: 0;">
            <a href="/auth/google/connect" style="padding: 6px 14px; font-size: 12px; color: #0B0B0B; background: #22C55E; border-radius: 6px; text-decoration: none; font-weight: 600; white-space: nowrap;">Connect Google</a>
            <button onclick="this.parentElement.parentElement.remove(); localStorage.setItem('dismissGoogleBanner','1')" style="padding: 6px 10px; font-size: 12px; color: #94A3B8; background: none; border: 1px solid rgba(255,255,255,0.08); border-radius: 6px; cursor: pointer;">Dismiss</button>
          </div>
        </div>
        <script>if(localStorage.getItem('dismissGoogleBanner')==='1'){var b=document.getElementById('google-connect-banner');if(b)b.remove();}</script>
        <% } %>
        <%~ it.body %>
      </main>
    </div>
  </div>

  <script>
  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const layout = document.querySelector('.app-layout');
    sidebar.classList.toggle('collapsed');
    layout.classList.toggle('sidebar-collapsed');
    localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
  }
  // Restore sidebar state
  if (localStorage.getItem('sidebarCollapsed') === 'true') {
    document.getElementById('sidebar').classList.add('collapsed');
    document.querySelector('.app-layout').classList.add('sidebar-collapsed');
  }

  // Nav group accordion
  function toggleNavGroup(btn) {
    const group = btn.closest('.nav-group');
    group.classList.toggle('open');
    saveNavGroupState();
  }
  function saveNavGroupState() {
    const open = [];
    document.querySelectorAll('.nav-group.open .nav-group-label .nav-label').forEach(el => {
      open.push(el.textContent.trim());
    });
    localStorage.setItem('navGroupsOpen', JSON.stringify(open));
  }
  // Restore nav group state (only for groups not auto-opened by active page)
  (function() {
    const saved = JSON.parse(localStorage.getItem('navGroupsOpen') || '[]');
    document.querySelectorAll('.nav-group').forEach(group => {
      const label = group.querySelector('.nav-group-label .nav-label')?.textContent.trim();
      if (label && saved.includes(label)) group.classList.add('open');
    });
  })();

  // Preserve sidebar scroll position across page navigations
  (function() {
    var nav = document.querySelector('.sidebar-nav');
    if (!nav) return;
    var saved = sessionStorage.getItem('sidebarScroll');
    if (saved) nav.scrollTop = parseInt(saved, 10);
    document.addEventListener('click', function(e) {
      var link = e.target.closest('.sidebar-nav a');
      if (link) sessionStorage.setItem('sidebarScroll', nav.scrollTop);
    });
  })();

  // --- Notifications ---
  var notifPanelOpen = false;
  function toggleNotifPanel() {
    notifPanelOpen = !notifPanelOpen;
    document.getElementById('notif-panel').style.display = notifPanelOpen ? 'block' : 'none';
    if (notifPanelOpen) loadNotifications();
  }
  document.addEventListener('click', function(e) {
    var bell = document.getElementById('notif-bell');
    var panel = document.getElementById('notif-panel');
    if (bell && panel && !bell.contains(e.target) && !panel.contains(e.target)) {
      notifPanelOpen = false;
      panel.style.display = 'none';
    }
  });
  function loadNotifications() {
    fetch('/api/notifications').then(function(r) { return r.json(); }).then(function(data) {
      var badge = document.getElementById('notif-badge');
      if (data.unread > 0) { badge.style.display = 'block'; badge.textContent = data.unread; }
      else { badge.style.display = 'none'; }
      var list = document.getElementById('notif-list');
      if (!data.notifications || data.notifications.length === 0) {
        list.innerHTML = '<div style="text-align: center; padding: 1.5rem; color: #64748B;">No notifications</div>';
        return;
      }
      list.innerHTML = data.notifications.map(function(n) {
        var bg = n.read ? 'transparent' : 'rgba(34,197,94,0.06)';
        var time = new Date(n.created_at + 'Z').toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
        var linkStart = n.link ? '<a href="' + n.link + '" style="text-decoration: none; color: inherit;">' : '';
        var linkEnd = n.link ? '</a>' : '';
        return linkStart + '<div style="padding: 0.6rem 0.75rem; background: ' + bg + '; border-radius: 6px; margin-bottom: 2px;" onclick="markNotifRead(' + n.id + ', this)">'
          + '<div style="color: #E2E8F0; font-weight: ' + (n.read ? '400' : '500') + ';">' + n.title + '</div>'
          + (n.body ? '<div style="color: #94A3B8; font-size: 12px; margin-top: 2px;">' + n.body + '</div>' : '')
          + '<div style="color: #64748B; font-size: 11px; margin-top: 2px;">' + time + '</div>'
          + '</div>' + linkEnd;
      }).join('');
    }).catch(function() {});
  }
  function markNotifRead(id, el) {
    fetch('/api/notifications/' + id + '/read', { method: 'POST' });
    if (el) el.style.background = 'transparent';
  }
  function markAllNotifRead() {
    fetch('/api/notifications/read-all', { method: 'POST' }).then(function() {
      loadNotifications();
      var badge = document.getElementById('notif-badge');
      if (badge) badge.style.display = 'none';
    });
  }
  // Poll for unread count every 60s
  (function pollNotifs() {
    fetch('/api/notifications/count').then(function(r) { return r.json(); }).then(function(data) {
      var badge = document.getElementById('notif-badge');
      if (badge) {
        if (data.unread > 0) { badge.style.display = 'block'; badge.textContent = data.unread; }
        else { badge.style.display = 'none'; }
      }
    }).catch(function() {});
    setTimeout(pollNotifs, 60000);
  })();
  </script>
</body>
</html>
