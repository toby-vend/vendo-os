{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["web/views/**/*.eta", "web/public/**", "context/**"]
      }
    },
    {
      "src": "api/chat.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["context/**"]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/renew-drive-channels",
      "schedule": "0 6 * * *"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/api/chat", "dest": "/api/chat.ts", "methods": ["POST"] },
    { "src": "/(.*)", "dest": "/api/index.ts" }
  ]
}
