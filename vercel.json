{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": ["web/views/**", "web/views/**/*", "web/public/**", "context/**", ".claude/commands/skills/**"]
      }
    },
    {
      "src": "api/chat.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["context/**"]
      }
    },
    {
      "src": "api/skills-generate.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "api/skills-save.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/skills-outputs.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/slack/events.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 120
      }
    },
    {
      "src": "api/slack/commands.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 120
      }
    },
    {
      "src": "api/cron/atlas-brief.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "api/cron/concern-monitor.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "api/agent/chat.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "api/agent/approve.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "api/agent/conversations.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/renew-drive-channels",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/monitors",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/atlas-brief",
      "schedule": "0 7 * * 1-5"
    },
    {
      "path": "/api/cron/concern-monitor",
      "schedule": "0 9-18 * * 1-5"
    },
    {
      "path": "/api/cron/sync-actions-to-asana",
      "schedule": "45 7 * * 1-5"
    },
    {
      "path": "/api/cron/health-score",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/traffic-light",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/traffic-light-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/sync-xero",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/sync-google-ads",
      "schedule": "15 */4 * * *"
    },
    {
      "path": "/api/cron/sync-meta-ads",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/sync-ghl",
      "schedule": "45 */4 * * *"
    },
    {
      "path": "/api/cron/lead-scoring",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/upsell-detection",
      "schedule": "0 10 * * 3"
    },
    {
      "path": "/api/cron/nps-trigger",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/onboarding-stall",
      "schedule": "0 9 * * 2"
    },
    {
      "path": "/api/cron/performance-review-gaps",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/specialist-paid-social",
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/cron/specialist-paid-search",
      "schedule": "30 9 * * 1-5"
    },
    {
      "path": "/api/cron/specialist-seo",
      "schedule": "0 10 * * 1-5"
    },
    {
      "path": "/api/cron/specialist-creative",
      "schedule": "30 10 * * 1-5"
    },
    {
      "path": "/api/cron/specialist-am",
      "schedule": "0 11 * * 1-5"
    },
    {
      "path": "/api/cron/monthly-client-reports",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/capacity-digest",
      "schedule": "30 8 * * 1"
    },
    {
      "path": "/api/cron/sales-pipeline-digest",
      "schedule": "0 17 * * 5"
    },
    {
      "path": "/api/cron/case-study-detection",
      "schedule": "0 7 * * 3"
    },
    {
      "path": "/api/cron/sync-asana",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/pull-onboarding-from-portal",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/client-profitability",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/push-clients-to-portal",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/purge-suggestion-drafts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/frameio-process",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/sync-frameio",
      "schedule": "30 3 * * *"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/sw.js", "headers": { "Cache-Control": "public, max-age=0, must-revalidate" }, "dest": "/public/sw.js" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/api/chat", "dest": "/api/chat.ts", "methods": ["POST"] },
    { "src": "/api/skills/generate", "dest": "/api/skills-generate.ts", "methods": ["POST"] },
    { "src": "/api/skills/save", "dest": "/api/skills-save.ts", "methods": ["POST"] },
    { "src": "/api/skills/outputs", "dest": "/api/skills-outputs.ts", "methods": ["GET"] },
    { "src": "/api/slack/events", "dest": "/api/slack/events.ts", "methods": ["POST"] },
    { "src": "/api/slack/commands", "dest": "/api/slack/commands.ts", "methods": ["POST"] },
    { "src": "/api/cron/atlas-brief", "dest": "/api/cron/atlas-brief.ts", "methods": ["GET", "POST"] },
    { "src": "/api/cron/concern-monitor", "dest": "/api/cron/concern-monitor.ts", "methods": ["GET", "POST"] },
    { "src": "/api/agent/chat", "dest": "/api/agent/chat.ts", "methods": ["POST"] },
    { "src": "/api/agent/approve", "dest": "/api/agent/approve.ts", "methods": ["POST"] },
    { "src": "/api/agent/conversations(/.*)?", "dest": "/api/agent/conversations.ts" },
    { "src": "/(.*)", "dest": "/api/index.ts" }
  ]
}
